<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.QuizReviewController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="15">
            <Label fx:id="titleLabel"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox style="-fx-padding: 25;" spacing="15">

                <Label fx:id="subtitleLabel"
                       style="-fx-text-fill: #888; -fx-font-size: 13px;"/>

                <HBox spacing="20">

                    <VBox style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 6;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                          spacing="8" HBox.hgrow="ALWAYS" minWidth="280">
                        <Label text="Schedule"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label fx:id="startsLabel" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                        <Label fx:id="endsLabel" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                        <Label fx:id="durationLabel" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                    </VBox>

                    <VBox style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 6;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                          spacing="8" HBox.hgrow="ALWAYS" minWidth="280">
                        <Label text="Summary"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label fx:id="attemptsLabel" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                        <Label fx:id="averageScoreLabel" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                        <Label fx:id="releasedLabel" style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                        <Button fx:id="releaseButton" text="Release Results" onAction="#handleReleaseResults"
                                style="-fx-background-color: #0077b6; -fx-text-fill: white;
                                       -fx-padding: 6 14; -fx-background-radius: 4; -fx-cursor: hand;
                                       -fx-font-size: 12px;"/>
                        <Label fx:id="feedbackLabel" style="-fx-font-size: 11px;"/>
                        <Hyperlink text="← Back to quizzes" onAction="#handleBack"/>
                    </VBox>

                </HBox>

                <VBox style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 6;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);" spacing="8">
                    <Label text="Questions"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Label text="Preview only — lecturers cannot attempt quizzes."
                           style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>