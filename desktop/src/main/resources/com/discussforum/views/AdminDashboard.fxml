<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.AdminDashboardController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="20">
            <Label text="Smart Discussion Forum"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

   <left>
    <VBox style="-fx-background-color: #023e8a; -fx-padding: 20 0;"
          minWidth="180" spacing="5">
        <Label text="MENU"
               style="-fx-text-fill: #90c8e0; -fx-font-size: 11px; -fx-padding: 0 15 5 15;"/>
        <Button text="Dashboard"
                maxWidth="Infinity"
                style="-fx-background-color: #0077b6; -fx-text-fill: white;
                       -fx-padding: 10 15; -fx-cursor: hand;"/>
        <Button text="Register Lecturer" onAction="#openRegisterLecturer"
                maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-padding: 10 15; -fx-cursor: hand;"/>
        <Button text="View Groups" onAction="#openViewGroups"
                maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-padding: 10 15; -fx-cursor: hand;"/>
        <Button text="View Discussions" onAction="#openViewDiscussions"
                maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-padding: 10 15; -fx-cursor: hand;"/>
    </VBox>
</left>

   <center>
    <ScrollPane fitToWidth="true"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox style="-fx-padding: 20;" spacing="20">

            <Label text="Platform Overview"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
            <Label text="Monitor activity and manage lecturer accounts across the system."
                   style="-fx-text-fill: #666; -fx-font-size: 13px;"/>

            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #888; -fx-font-size: 13px;" text="Loading dashboard..."/>

            <!-- Stat Cards -->
            <HBox spacing="15">
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 15; -fx-min-width: 140;" spacing="8">
                    <Label text="👤" style="-fx-font-size: 20px; -fx-background-color: #eaf4fb;
                           -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <Label fx:id="totalUsersLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
                    <Label text="Total Users" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 15; -fx-min-width: 140;" spacing="8">
                    <Label text="🎓" style="-fx-font-size: 20px; -fx-background-color: #eaf4fb;
                           -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <Label fx:id="totalLecturersLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
                    <Label text="Lecturers" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 15; -fx-min-width: 140;" spacing="8">
                    <Label text="📖" style="-fx-font-size: 20px; -fx-background-color: #eaf4fb;
                           -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <Label fx:id="totalStudentsLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
                    <Label text="Students" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 15; -fx-min-width: 140;" spacing="8">
                    <Label text="👥" style="-fx-font-size: 20px; -fx-background-color: #eaf4fb;
                           -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <Label fx:id="totalGroupsLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
                    <Label text="Groups" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-padding: 15; -fx-min-width: 140;" spacing="8">
                    <Label text="💬" style="-fx-font-size: 20px; -fx-background-color: #eaf4fb;
                           -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <Label fx:id="totalDiscussionsLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
                    <Label text="Discussions" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <!-- Quick Actions -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;" spacing="12">
                <Label text="⚙ Quick Actions" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #023e8a;"/>
                <Button text="+ Register New Lecturer" onAction="#openRegisterLecturer"
                        style="-fx-background-color: #0077b6; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </ScrollPane>
</center>

</BorderPane>