<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.CreateGroupController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="15">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4; -fx-cursor: hand;"/>
            <Label text="Create New Group"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-padding: 40;" spacing="0" alignment="TOP_CENTER">
            <VBox maxWidth="500"
                  style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
                  spacing="15">

                <Label text="Group Name"
                       style="-fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
                <TextField fx:id="nameField"
                           promptText="Enter group name"
                           style="-fx-padding: 10; -fx-border-color: #b0c4d8;
                                  -fx-border-radius: 4; -fx-background-radius: 4;"/>

                <Label text="Description"
                       style="-fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
                <TextArea fx:id="descriptionField"
                          promptText="Enter group description (optional)"
                          prefRowCount="3"
                          style="-fx-padding: 10; -fx-border-color: #b0c4d8;
                                 -fx-border-radius: 4; -fx-background-radius: 4;"/>

                <Label text="Visibility"
                       style="-fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
                <ComboBox fx:id="visibilityBox" maxWidth="Infinity"/>

                <Label fx:id="feedbackLabel"
                       style="-fx-font-size: 12px;" text="" wrapText="true"/>

                <Button fx:id="createButton"
                        text="Create Group"
                        onAction="#handleCreate"
                        maxWidth="Infinity"
                        style="-fx-background-color: #0077b6; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 10;
                               -fx-background-radius: 4; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
