<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.GroupsController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="20">
            <Label text="Smart Discussion Forum"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button text="+ New Group" onAction="#openCreateGroup"
                    style="-fx-background-color: white; -fx-text-fill: #0077b6;
                           -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    </left>

    <center>
        <VBox style="-fx-padding: 20;" spacing="15">

            <!-- Page-local sub-nav for this screen only: My Groups / Discover / My Quizzes.
                 This is NOT part of the shared global sidebar. -->
            <HBox spacing="8">
                <Button text="My Groups" onAction="#loadMyGroups"
                        style="-fx-background-color: #0077b6; -fx-text-fill: white;
                               -fx-padding: 6 14; -fx-background-radius: 4; -fx-cursor: hand;"/>
                <Button text="Discover Groups" onAction="#loadDiscoverGroups"
                        style="-fx-background-color: #e0ecf7; -fx-text-fill: #0077b6;
                               -fx-padding: 6 14; -fx-background-radius: 4; -fx-cursor: hand;"/>
                <Button fx:id="myQuizzesButton" text="My Quizzes" onAction="#openMyQuizzes"
                        style="-fx-background-color: #e0ecf7; -fx-text-fill: #0077b6;
                               -fx-padding: 6 14; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </HBox>

            <Label fx:id="sectionTitle"
                   text="My Groups"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #888; -fx-font-size: 13px;" text="Loading..."/>
            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="groupsList" spacing="10"/>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
