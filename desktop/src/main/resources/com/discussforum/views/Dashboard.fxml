<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.DashboardController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="20">
            <Label text="Smart Discussion Forum"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <left>
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
</left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox style="-fx-padding: 25;" spacing="20">

                <VBox spacing="4">
                    <Label fx:id="welcomeLabel"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #222;"/>
                    <Label text="Let's continue our journey."
                           style="-fx-text-fill: #666; -fx-font-size: 13px;"/>
                </VBox>

                <HBox fx:id="statsRow" spacing="15"/>

                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <VBox style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 6;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                          spacing="12" HBox.hgrow="ALWAYS" minWidth="260">
                        <Label text="Recent Discussions"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
                        <VBox fx:id="discussionsList" spacing="10"/>
                    </VBox>

                    <VBox style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 6;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                          spacing="12" HBox.hgrow="ALWAYS" minWidth="260">
                        <Label text="Upcoming Quizzes"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
                        <VBox fx:id="quizzesList" spacing="10"/>
                    </VBox>

                    <VBox style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 6;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                          spacing="12" HBox.hgrow="ALWAYS" minWidth="260">
                        <Label text="Recommended For You"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
                        <VBox fx:id="recommendationsList" spacing="10"/>
                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>