<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.QuizDetailController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="15">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4; -fx-cursor: hand;"/>
            <VBox>
                <Label fx:id="titleLabel"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="subtitleLabel"
                       style="-fx-text-fill: white; -fx-opacity: 0.85; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 6 16;
                                            -fx-background-radius: 8;">
                <Label text="Time remaining" style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
                <Label fx:id="countdownLabel" text="--:--"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a7a45;"/>
            </VBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox style="-fx-padding: 20;" spacing="15">
                <Label fx:id="statusLabel" style="-fx-text-fill: #888; -fx-font-size: 13px;" text="Loading..."/>
                <VBox fx:id="questionsContainer" spacing="12"/>
                <Label fx:id="feedbackLabel" style="-fx-font-size: 12px;" text="" wrapText="true"/>
                <Button fx:id="submitButton" text="Submit Quiz" onAction="#handleSubmit"
                        maxWidth="Infinity"
                        style="-fx-background-color: #0077b6; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 10;
                               -fx-background-radius: 4; -fx-cursor: hand;"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
