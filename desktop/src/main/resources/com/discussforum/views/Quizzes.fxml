<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.discussforum.controllers.QuizzesController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #0077b6; -fx-padding: 15 20;"
              alignment="CENTER_LEFT" spacing="20">
            <Label text="Smart Discussion Forum"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-background-color: #023e8a; -fx-padding: 20 0;"
              minWidth="180" spacing="5">
            <Label text="MENU"
                   style="-fx-text-fill: #90c8e0; -fx-font-size: 11px; -fx-padding: 0 15 5 15;"/>
            <Button text="My Groups" onAction="#goToMyGroups"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-padding: 10 15; -fx-cursor: hand;"/>
            <Button text="Discover Groups" onAction="#goToDiscoverGroups"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-padding: 10 15; -fx-cursor: hand;"/>
            <Button text="My Quizzes"
                    maxWidth="Infinity"
                    style="-fx-background-color: #0077b6; -fx-text-fill: white;
                           -fx-padding: 10 15; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-padding: 20;" spacing="15">
            <Label text="My Quizzes"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0077b6;"/>
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #888; -fx-font-size: 13px;" text="Loading..."/>
            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="quizzesList" spacing="10"/>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>