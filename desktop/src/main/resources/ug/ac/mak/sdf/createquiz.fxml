<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ug.ac.mak.sdf.CreateQuizController"
            stylesheets="@style.css">

    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="groups-scroll">
            <VBox styleClass="main-content" spacing="18">
                <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>

                <Label fx:id="backLabel" text="← Back to Group" styleClass="back-link" />

                <Label fx:id="pageTitleLabel" text="Create Quiz" styleClass="page-title" />

                <VBox styleClass="discussion-card" spacing="10">
                    <padding><Insets top="16" right="18" bottom="16" left="18" /></padding>

                    <Label text="Quiz Title" styleClass="field-label" />
                    <TextField fx:id="titleField" styleClass="search-field" promptText="e.g. Chapter 3 Quiz" />

                    <Label text="Start Time" styleClass="field-label" />
                    <TextField fx:id="startTimeField" styleClass="search-field"
                               promptText="YYYY-MM-DD HH:MM (e.g. 2026-07-25 14:00)" />

                    <Label text="Duration (minutes)" styleClass="field-label" />
                    <Spinner fx:id="durationSpinner" editable="true" />
                </VBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Questions" styleClass="section-label" />
                    <HBox HBox.hgrow="ALWAYS" />
                    <Button text="+ Add Question" styleClass="action-button" onAction="#handleAddQuestion" />
                </HBox>

                <VBox fx:id="questionsContainer" spacing="14" />

                <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" />

                <HBox spacing="10">
                    <Button text="Create Quiz" styleClass="new-group-button" onAction="#handleSubmit" />
                    <Button text="Cancel" styleClass="blacklist-button" onAction="#handleCancel" />
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
