<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ug.ac.mak.sdf.TopicsController"
            stylesheets="@style.css">
         <top>
    <fx:include source="topbar.fxml" />
</top>
    <left>
       <fx:include source="sidebar.fxml" fx:id="sidebar" />
   </left>

    <center>
        <VBox styleClass="main-content" spacing="18">
            <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>

            <HBox spacing="10">
                <Button fx:id="backButton" text="← Back to discussions" styleClass="action-button" />
                <Button text="📄 Export to PDF" styleClass="action-button" />
                <Button text="🔗 Share Discussion" styleClass="action-button" />
            </HBox>

            <VBox styleClass="discussion-card" spacing="4">
                <padding><Insets top="16" right="18" bottom="16" left="18" /></padding>
                <Label fx:id="discussionTitleLabel" styleClass="discussion-title" />
                <Label fx:id="discussionMetaLabel" styleClass="discussion-meta" />
                <Label fx:id="discussionDescLabel" styleClass="discussion-desc" wrapText="true" />
            </VBox>

            <HBox alignment="CENTER_LEFT">
                <Label text="Topics" styleClass="page-title" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button text="+ Add Topic" styleClass="new-group-button" onAction="#handleAddTopic" />
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="groups-scroll">
                <VBox fx:id="topicsContainer" spacing="14" />
            </ScrollPane>

            <Label fx:id="statusLabel" styleClass="status-label" />
        </VBox>
    </center>

</BorderPane>