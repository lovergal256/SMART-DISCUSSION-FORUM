<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ug.ac.mak.sdf.AllDiscussionsController"
            stylesheets="@style.css">

    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <VBox styleClass="main-content" spacing="18">
            <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>

            <Label text="Discussions" styleClass="page-title" />

            <VBox styleClass="search-panel" spacing="10">
                <TextField fx:id="searchField" promptText="Search discussions..." styleClass="search-field" />
                <Button text="Search" styleClass="new-group-button" onAction="#handleSearch" />
            </VBox>

            <ScrollPane fitToWidth="true" styleClass="groups-scroll">
                <VBox fx:id="discussionsContainer" spacing="14" />
            </ScrollPane>

            <Label fx:id="statusLabel" styleClass="status-label" />
        </VBox>
    </center>

</BorderPane>