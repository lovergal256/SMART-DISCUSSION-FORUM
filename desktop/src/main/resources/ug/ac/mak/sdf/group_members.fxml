<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ug.ac.mak.sdf.GroupMembersController"
            stylesheets="@style.css">

    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <VBox styleClass="main-content" spacing="16">
            <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>

            <HBox spacing="14">
                <Button text="← Back to Groups" styleClass="back-button" onAction="#handleBack" />
                <Label fx:id="titleLabel" styleClass="page-title" />
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="groups-scroll">
                <VBox fx:id="membersContainer" spacing="10" />
            </ScrollPane>

            <Label fx:id="statusLabel" styleClass="status-label" />
        </VBox>
    </center>

</BorderPane>