<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ug.ac.mak.sdf.QuizReviewController"
            stylesheets="@style.css">

    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <VBox styleClass="main-content" spacing="16">
            <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>

            <Button text="← Back to Quizzes" styleClass="back-button" onAction="#handleBack" />
            <Label fx:id="titleLabel" styleClass="page-title" />
            <Label fx:id="scheduleLabel" styleClass="topic-meta" wrapText="true" />
            <Label fx:id="statsLabel" styleClass="topic-meta" wrapText="true" />
            <Label fx:id="releaseStatusLabel" styleClass="topic-meta" wrapText="true" />

            <Button fx:id="releaseResultsButton"
                    text="Release Results to Students"
                    styleClass="new-group-button"
                    onAction="#handleReleaseResults" />

            <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
